# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Anthropic API key for Claude agents (required)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token (optional — for agent git operations)
GITHUB_TOKEN=ghp_...

# Project root (set automatically in devcontainer; override locally if needed)
# PROJECT_ROOT=/path/to/ai-finance-paper
