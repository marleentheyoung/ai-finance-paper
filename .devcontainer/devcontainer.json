{
  // ── Identity ─────────────────────────────────────────────────────────────
  "name": "ai-finance-paper",

  // ── Build ─────────────────────────────────────────────────────────────────
  // Build the image from the local Dockerfile rather than pulling a pre-built
  // image, so all tooling versions are pinned and reproducible.
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // ── Workspace ─────────────────────────────────────────────────────────────
  // Mount the repository root inside the container at the standard VS Code path.
  "workspaceFolder": "/workspaces/ai-finance-paper",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/ai-finance-paper,type=bind,consistency=cached",

  // ── Security isolation ────────────────────────────────────────────────────
  // The container runs as the non-root `vscode` user provided by the base image.
  // No privileged access, no host network, no extra capabilities.
  // This is what makes it safe to run:
  //   claude --dangerously-skip-permissions
  // The flag bypasses Claude Code's interactive permission prompts, but the
  // container boundary itself prevents any action from escaping to the host.
  "remoteUser": "vscode",
  "containerUser": "vscode",

  // ── Resource limits ───────────────────────────────────────────────────────
  // Cap CPU and RAM so that runaway multi-agent workloads cannot starve the
  // host. Adjust --memory and --cpus to fit your machine. The ulimits prevent
  // fork-bomb style process explosions from a looping agent.
  "runArgs": [
    "--memory=8g",
    "--cpus=4",
    "--ulimit", "nofile=1024:1024",
    "--ulimit", "nproc=256:512"
  ],

  // ── Mounts ────────────────────────────────────────────────────────────────
  // Persist the VS Code server extensions and bash history across rebuilds.
  "mounts": [],

  // ── Environment variables ─────────────────────────────────────────────────
  "remoteEnv": {
    // Let Python scripts find the workspace root without hardcoding paths.
    "PROJECT_ROOT": "/workspaces/ai-finance-paper",
    // Prevent Python from writing .pyc files into the mounted source tree.
    "PYTHONDONTWRITEBYTECODE": "1",
    // Force unbuffered stdout/stderr so script output appears immediately.
    "PYTHONUNBUFFERED": "1",
    // Pass API keys from the host into the container. Set these in your
    // host shell profile (e.g. ~/.zshrc) — never hardcode them here.
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },

  // ── VS Code extensions ────────────────────────────────────────────────────
  // Installed automatically when the container is first created.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",              // Python language support & debugger
        "ms-python.vscode-pylance",      // Fast type checking via Pylance
        "ms-toolsai.jupyter",            // Jupyter notebook support
        "James-Yu.latex-workshop",       // LaTeX compilation and PDF preview
        "GitHub.copilot",                // GitHub Copilot inline suggestions
        "eamodio.gitlens",               // Enhanced git history and blame
        "anthropic.claude-code",         // Claude Code IDE integration
        "github.vscode-pull-request-github" // GitHub PRs and issues
      ],
      "settings": {
        // Point the Python extension at the system interpreter inside the container.
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        // LaTeX Workshop: use latexmk as the build tool.
        "latex-workshop.latex.tools": [
          {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
              "-pdf",
              "-interaction=nonstopmode",
              "-outdir=paper",
              "%DOC%"
            ]
          }
        ],
        "latex-workshop.latex.recipes": [
          {
            "name": "latexmk",
            "tools": ["latexmk"]
          }
        ],
        // Show the integrated terminal in the project root by default.
        "terminal.integrated.cwd": "/workspaces/ai-finance-paper"
      }
    }
  },

  // ── Post-create setup ─────────────────────────────────────────────────────
  // Runs once after the container is built and the workspace is mounted.
  // Installs dependencies, sets up pre-commit hooks, and verifies all tooling.
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode && if [ -f .devcontainer/postCreateCommand.sh ]; then bash .devcontainer/postCreateCommand.sh; fi",

  // ── Forward ports ─────────────────────────────────────────────────────────
  // Uncomment if any script starts a local server (e.g. a Jupyter notebook).
  // "forwardPorts": [8888],

  // ── Lifecycle hooks ───────────────────────────────────────────────────────
  // Keep bash history in the persistent volume so it survives rebuilds.
  "postStartCommand": "bash -c 'ln -sf /home/vscode/.bash_history_vol/.bash_history /home/vscode/.bash_history 2>/dev/null || true'",
}
